#!/bin/sh
BONES_BASE="/usr/lib/extensions/vulkan/bones/lib"
LAYERS="$BONES_BASE/x86_64"
[ -d "$BONES_BASE/i686" ] && LAYERS="$LAYERS:$BONES_BASE/i686"
export VK_ADD_LAYER_PATH="${LAYERS}${VK_ADD_LAYER_PATH:+:$VK_ADD_LAYER_PATH}"
export VK_INSTANCE_LAYERS="VK_LAYER_BONES_overlay${VK_INSTANCE_LAYERS:+:$VK_INSTANCE_LAYERS}"
exec "$@"
